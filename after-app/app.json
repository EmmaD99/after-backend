{
  "expo": {
    "name": "AFTER",
    "slug": "after-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "after",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d0a07",
    "splash": {
      "backgroundColor": "#0d0a07"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.after.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0a07"
      },
      "package": "com.after.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "AFTER utilise tes photos pour ton profil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
